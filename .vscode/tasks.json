{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "gitgraph: build vscode (watch)",
      "type": "shell",
      "command": "bun run --cwd packages/vscode dev",
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": {
        "owner": "gitgraph",
        "pattern": [
          {
            "regexp": "^$"
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Done in|build finished|watching)"
        }
      }
    }
  ]
}
