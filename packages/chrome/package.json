{
  "name": "@gitgraph/chrome",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "dev": "node esbuild.config.mjs --watch",
    "clean": "rm -rf dist dist-types .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@gitgraph/core": "workspace:*",
    "@gitgraph/graph-renderer": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.281",
    "esbuild": "^0.24.0",
    "vitest": "^2.1.0"
  }
}
