{
  "manifest_version": 3,
  "name": "gitGraph",
  "version": "0.1.0",
  "description": "Visual dependency-aware diff analysis for GitHub PRs.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "gitGraph settings"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
