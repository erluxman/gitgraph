# Source — only `dist/` is needed at runtime.
src/**
dist-types/**
tsconfig.json
*.tsbuildinfo
vitest.config.ts

# Build tooling
esbuild.config.mjs
node_modules/**

# Dev artifacts
.turbo/**
*.log
*.vsix
